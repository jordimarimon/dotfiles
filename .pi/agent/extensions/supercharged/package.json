{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "supercharged",
    "packageManager": "pnpm@11.8.0",
    "type": "module",
    "engines": {
        "node": "^24.16.0",
        "pnpm": "11.8.0"
    },
    "pi": {
        "extensions": [
            "./dist/index.js"
        ]
    },
    "scripts": {
        "build": "rolldown -c",
        "test": "node --test",
        "format": "oxfmt \"**/*.{js,json,md,ts}\"",
        "lint": "oxlint --fix",
        "typecheck": "tsc --noEmit"
    },
    "imports": {
        "#src/*.ts": "./src/*.ts",
        "#tests/*.ts": "./tests/*.ts"
    },
    "dependencies": {
        "shell-quote": "^1.10.0",
        "tslib": "^2.8.1",
        "typebox": "^1.3.6"
    },
    "devDependencies": {
        "@earendil-works/pi-agent-core": "^0.80.10",
        "@earendil-works/pi-coding-agent": "^0.80.10",
        "@earendil-works/pi-tui": "^0.80.10",
        "@types/node": "^26.1.1",
        "@types/shell-quote": "^1.7.5",
        "oxfmt": "^0.59.0",
        "oxlint": "^1.74.0",
        "oxlint-tsgolint": "^0.25.0",
        "rolldown": "^1.2.0",
        "typescript": "^7.0.2"
    }
}
