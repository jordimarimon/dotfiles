{
    "$schema": "https://opencode.ai/config.json",
    "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"],
    "mcp": {
        "youtrack": {
            "enabled": false,
            "type": "remote",
            "url": "https://interactiu.youtrack.cloud/mcp",
            "oauth": false,
            "headers": {
                "Authorization": "Bearer {env:YOUTRACK_TOKEN}"
            }
        }
    },
    "lsp": {
        "intelephense": {
            "disabled": false,
            "command": ["intelephense", "--stdio"],
            "extensions": [".php"],
            "initialization": {
                "licenceKey": "/home/jmarimon/intelephense/licence.txt",
                "files": {
                    "exclude": [
                        "**/.git/**",
                        "**/.svn/**",
                        "**/.hg/**",
                        "**/CVS/**",
                        "**/.DS_Store/**",
                        "**/node_modules/**",
                        "**/bower_components/**",
                        "**/vendor/**/{Tests,tests}/**",
                        "**/.history/**"
                    ]
                },
                "stubs": [
                    "apache",
                    "bcmath",
                    "bz2",
                    "calendar",
                    "com_dotnet",
                    "Core",
                    "ctype",
                    "curl",
                    "date",
                    "dba",
                    "dom",
                    "enchant",
                    "exif",
                    "FFI",
                    "fileinfo",
                    "filter",
                    "fpm",
                    "ftp",
                    "gd",
                    "gettext",
                    "gmp",
                    "hash",
                    "iconv",
                    "imagick",
                    "imap",
                    "intl",
                    "json",
                    "ldap",
                    "libxml",
                    "mbstring",
                    "meta",
                    "mongo",
                    "mongodb",
                    "mysqli",
                    "oci8",
                    "odbc",
                    "openssl",
                    "pcntl",
                    "pcre",
                    "PDO",
                    "pgsql",
                    "Phar",
                    "posix",
                    "pspell",
                    "random",
                    "readline",
                    "Reflection",
                    "session",
                    "shmop",
                    "SimpleXML",
                    "snmp",
                    "soap",
                    "sockets",
                    "sodium",
                    "SPL",
                    "sqlite3",
                    "standard",
                    "superglobals",
                    "sysvmsg",
                    "sysvsem",
                    "sysvshm",
                    "tidy",
                    "tokenizer",
                    "uri",
                    "xml",
                    "xmlreader",
                    "xmlrpc",
                    "xmlwriter",
                    "xsl",
                    "Zend OPcache",
                    "zip",
                    "zlib"
                ]
            }
        }
    }
}
